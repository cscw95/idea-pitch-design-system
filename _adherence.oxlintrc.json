{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/blocks/**",
              "components/structure/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:NanumSquare))/i]",
        "message": "Font not provided by the design system. Available: NanumSquare."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChipRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|title|sub|chipWidth|style|key|ref|className|style|children)$/]",
        "message": "<ChipRow> doesn't accept that prop. Declared props: label, title, sub, chipWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmphasisBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<EmphasisBand> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntityBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:tense|title|sub|children|style|key|ref|className|style|children)$/]",
        "message": "<EntityBox> doesn't accept that prop. Declared props: tense, title, sub, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntityBox'] > JSXAttribute[name.name='tense'] > Literal[value!=/^(?:past|plan|future)$/]",
        "message": "<EntityBox> tense must be one of 'past' | 'plan' | 'future'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlowArrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:direction|color|style|key|ref|className|style|children)$/]",
        "message": "<FlowArrow> doesn't accept that prop. Declared props: direction, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlowArrow'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:right|up)$/]",
        "message": "<FlowArrow> direction must be one of 'right' | 'up'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GoverningHeadline'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<GoverningHeadline> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LabelChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<LabelChip> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|subhead|children|style|key|ref|className|style|children)$/]",
        "message": "<SectionCard> doesn't accept that prop. Declared props: label, subhead, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|kicker|title|desc|page|total|logoSrc|style|key|ref|className|style|children)$/]",
        "message": "<SectionDivider> doesn't accept that prop. Declared props: number, kicker, title, desc, page, total, logoSrc, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:page|total|logoSrc|source|showRule|style|key|ref|className|style|children)$/]",
        "message": "<SlideFooter> doesn't accept that prop. Declared props: page, total, logoSrc, source, showRule, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<SlideFrame> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SlideHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:deck|section|subtitle|showRule|style|key|ref|className|style|children)$/]",
        "message": "<SlideHeader> doesn't accept that prop. Declared props: deck, section, subtitle, showRule, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TakeawayBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<TakeawayBar> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|sub|state|hot|key|ref|className|style|children)$/]",
        "message": "<TimelineItem> doesn't accept that prop. Declared props: label, sub, state, hot."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:done|open)$/]",
        "message": "<TimelineItem> state must be one of 'done' | 'open'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TitleSlide'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|subtitle|meta|logoSrc|style|key|ref|className|style|children)$/]",
        "message": "<TitleSlide> doesn't accept that prop. Declared props: eyebrow, title, subtitle, meta, logoSrc, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrackArrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<TrackArrow> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrackArrow'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:navy|steel|wait)$/]",
        "message": "<TrackArrow> variant must be one of 'navy' | 'steel' | 'wait'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
